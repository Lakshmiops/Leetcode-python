class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        left=0
        max_char=0
        seen={}
        for right in range(len(s)):
            if s[right] in seen:
                left=max(left,seen[s[right]]+1)
            seen[s[right]]=right
            max_char=max(max_char,right-left+1)
        return max_char
