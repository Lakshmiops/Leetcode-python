class Solution:
    def rotate(self, nums: List[int], k: int) -> None:
        n=len(nums)
        k=k%n
        self.rev(nums,0,n-1)
        self.rev(nums,0,k-1)
        self.rev(nums,k,n-1)
    def rev(self, nums: List[int], left: int, right: int) -> None:
        while left<right:
            nums[left],nums[right]=nums[right],nums[left]
            left+=1
            right-=1
