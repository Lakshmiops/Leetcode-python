class Solution(object):
    def findUnsortedSubarray(self, nums):
        left,right=-1,-1
        min_val=float('inf')
        for i in range(len(nums)-1,-1,-1):
            if nums[i]>min_val:
                left=i
            else:
                min_val=nums[i]
        max_val=float('-inf')
        for i in range(len(nums)):
            if nums[i]<max_val:
                right=i
            else:
                max_val=nums[i]
        return 0 if right==-1 else right-left+1
