class Solution:
    def countCharacters(self, words: List[str], chars: str) -> int:
        char_count=Counter(chars)
        total=0
        for word in words:
            word_count=Counter(word)
            valid=True
            for ch in word:
                if word_count[ch]>char_count[ch]:
                    valid=False
                    break
            if valid:
                total+=len(word)
        return total
