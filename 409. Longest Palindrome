class Solution:
    def longestPalindrome(self, s: str) -> int:
        word_length=0
        res=[]
        for i in range(len(s)):
            if s[i] in res:
                res.remove(s[i])
                word_length+=2
            else:
                res.append(s[i])
        if len(res)>0:
            word_length+=1
        return word_length
