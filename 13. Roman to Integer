class Solution:
    def romanToInt(self, s: str) -> int:
        curr_val=self.symbolToInt(s[0])
        summ=0
        for i in range(1, len(s)):
            next_val=self.symbolToInt(s[i])
            if curr_val<next_val:
                summ-=curr_val
            else:
                summ+=curr_val
            curr_val=next_val
        summ+=curr_val
        return summ
    def symbolToInt(self, c: str) -> int:
        match c:
            case 'I':
                return 1
            case 'V':
                return 5
            case 'X':
                return 10
            case 'L':
                return 50
            case 'C':
                return 100
            case 'D':
                return 500
            case 'M':
                return 1000
            case '_':
                return 0
