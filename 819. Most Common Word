class Solution:
    def mostCommonWord(self, paragraph: str, banned: List[str]) -> str:
        dict={}
        normal_string=''.join(para.lower() if para.isalnum() else ' ' for para in paragraph)
        for word in normal_string.split():
            if word not in banned:
                dict[word]=dict.get(word,0)+1
        max_val=0
        max_string=""
        for d in dict:
            if dict[d]>max_val:
                max_val=dict[d]
                max_string=d
        return max_string
