class Solution:
    def numUniqueEmails(self, emails: List[str]) -> int:
        unique_emails=set()
        for email in emails:
            local,domain=email.split("@")
            if "+" in local:
                local=local[0:local.index("+")]
            local=local.replace(".","")
            combined=local+"@"+domain
            unique_emails.add(combined)
        return len(unique_emails)
